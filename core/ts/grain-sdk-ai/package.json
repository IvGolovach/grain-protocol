{
  "name": "grain-sdk-ai-ts",
  "version": "0.2.0",
  "private": true,
  "description": "Optional Grain SDK AI sidecar (TOR-SDK-A03)",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "engines": {
    "node": ">=22"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "npm --prefix ../grain-ts-core run build --silent && npm --prefix ../grain-sdk run build --silent && npm run clean --silent && tsc -p tsconfig.build.json",
    "test:boundary": "npm run build --silent && node dist/scripts/test-sdk-ai-boundary.js"
  },
  "dependencies": {
    "grain-sdk-ts": "file:../grain-sdk",
    "grain-ts-core": "file:../grain-ts-core"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.9.2"
  }
}

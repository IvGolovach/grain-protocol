#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

usage() {
  cat <<'EOF'
Usage:
  ./scripts/verify [--out-dir <path>]
  ./scripts/verify --mode certify [certify options]

Default:
  Fast developer verification on host toolchains.

Certify path:
  Release-grade containerized verification with evidence bundle output.
  Shortcut: ./scripts/certify

Compatibility:
  Legacy certify flags on ./scripts/verify still route to ./scripts/certify.
EOF
}

mode="dev"
certify_args=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      if [[ "${2:-}" != "dev" && "${2:-}" != "certify" ]]; then
        echo "Unknown verify mode: ${2:-}" >&2
        usage >&2
        exit 2
      fi
      mode="$2"
      shift 2
      ;;
    --runtime|--image|--fuzz-smoke|--no-build-local-image|--allow-dirty)
      mode="certify"
      certify_args+=("$1")
      if [[ "$1" == "--runtime" || "$1" == "--image" ]]; then
        certify_args+=("${2:-}")
        shift 2
      else
        shift
      fi
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      certify_args+=("$1")
      if [[ "$1" == "--out-dir" ]]; then
        certify_args+=("${2:-}")
        shift 2
      else
        shift
      fi
      ;;
  esac
done

if [[ "$mode" == "certify" ]]; then
  exec "$ROOT/scripts/certify" "${certify_args[@]}"
fi

exec "$ROOT/scripts/internal/verify_dev.sh" "${certify_args[@]}"

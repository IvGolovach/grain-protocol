#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

OUT_DIR="artifacts/verify"
RUNTIME="${GRAIN_CONTAINER_RUNTIME:-}"
IMAGE="${GRAIN_VERIFY_IMAGE:-}"
ENABLE_FUZZ_SMOKE=0
BUILD_LOCAL_IMAGE=1
ALLOW_DIRTY=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --out-dir)
      OUT_DIR="$2"
      shift 2
      ;;
    --runtime)
      RUNTIME="$2"
      shift 2
      ;;
    --image)
      IMAGE="$2"
      shift 2
      ;;
    --fuzz-smoke)
      ENABLE_FUZZ_SMOKE=1
      shift
      ;;
    --no-build-local-image)
      BUILD_LOCAL_IMAGE=0
      shift
      ;;
    --allow-dirty)
      ALLOW_DIRTY=1
      shift
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

if [[ "$ALLOW_DIRTY" -ne 1 && -n "$(git status --porcelain)" ]]; then
  echo "PORT_ERR_DIRTY_TREE: working tree must be clean before verify" >&2
  exit 1
fi

if [[ -z "$RUNTIME" ]]; then
  if command -v docker >/dev/null 2>&1; then
    RUNTIME="docker"
  elif command -v podman >/dev/null 2>&1; then
    RUNTIME="podman"
  else
    echo "PORT_ERR_CONTAINER_RUNTIME_MISSING: install docker or podman" >&2
    exit 1
  fi
fi

if [[ "$RUNTIME" != "docker" && "$RUNTIME" != "podman" ]]; then
  echo "PORT_ERR_RUNTIME_UNSUPPORTED: expected docker or podman, got '$RUNTIME'" >&2
  exit 1
fi

if [[ -z "$IMAGE" ]]; then
  if [[ "$BUILD_LOCAL_IMAGE" -ne 1 ]]; then
    echo "PORT_ERR_IMAGE_UNSET: provide --image or allow local build" >&2
    exit 1
  fi
  IMAGE="grain-certify-local:$(git rev-parse --short HEAD)"
  "$RUNTIME" build \
    --file docker/grain-certify.Dockerfile \
    --tag "$IMAGE" \
    .
fi

mkdir -p "$OUT_DIR"

COMMIT_SHA="$(git rev-parse HEAD)"
OUT_DIR_ABS="$ROOT/$OUT_DIR"

"$RUNTIME" run --rm \
  -v "$ROOT":/work \
  -w /work \
  -e GRAIN_VERIFY_COMMIT_SHA="$COMMIT_SHA" \
  -e GRAIN_VERIFY_OUT_DIR="$OUT_DIR_ABS" \
  -e GRAIN_VERIFY_FUZZ_SMOKE="$ENABLE_FUZZ_SMOKE" \
  "$IMAGE" \
  /work/scripts/internal/verify_in_container.sh

echo "verify: PASS"
echo "evidence: $OUT_DIR_ABS/evidence/evidence_content.sha256"

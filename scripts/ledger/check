#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$ROOT"

history_mode=0
base_ref=""

usage() {
  cat <<'EOF'
Usage:
  scripts/ledger/check
  scripts/ledger/check --history --base <git-ref>

Checks repository hygiene for the current tree and verifies that commits in the
specified history range each carry exactly one well-formed Ledger-Id trailer.
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --history)
      history_mode=1
      shift
      ;;
    --base)
      base_ref="${2:-}"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ "$history_mode" -eq 0 ]]; then
  git diff --check
  git diff --cached --check
  python3 tools/ci/check_forbidden_tracked.py

  echo "ledger check: OK"
  exit 0
fi

if [[ -z "$base_ref" ]]; then
  echo "LEDGER_CHECK_ERR_BASE_REQUIRED: --history requires --base <git-ref>" >&2
  exit 2
fi

git rev-parse --verify "$base_ref" >/dev/null

mapfile -t commits < <(git rev-list --reverse "${base_ref}..HEAD")

declare -A ledger_id_by_commit=()
ledger_id_pattern='^[A-Za-z0-9][A-Za-z0-9._-]{5,80}$'

for sha in "${commits[@]}"; do
  [[ -n "$sha" ]] || continue
  mapfile -t ledger_ids < <(git log -1 --format=%B "$sha" | sed -n 's/^Ledger-Id:[[:space:]]*//p')
  trailer_count="${#ledger_ids[@]}"

  if [[ "$trailer_count" -ne 1 ]]; then
    echo "LEDGER_CHECK_ERR_TRAILER_COUNT: commit $sha has $trailer_count Ledger-Id trailers" >&2
    exit 1
  fi

  ledger_id="${ledger_ids[0]}"
  if [[ ! "$ledger_id" =~ $ledger_id_pattern ]]; then
    echo "LEDGER_CHECK_ERR_TRAILER_FORMAT: commit $sha has invalid Ledger-Id '$ledger_id'" >&2
    exit 1
  fi
  if [[ -n "${ledger_id_by_commit[$ledger_id]:-}" ]]; then
    echo "LEDGER_CHECK_ERR_TRAILER_REUSED: Ledger-Id '$ledger_id' appears in ${ledger_id_by_commit[$ledger_id]} and $sha" >&2
    exit 1
  fi
  ledger_id_by_commit[$ledger_id]="$sha"
done

echo "ledger history check: OK (${#commits[@]} commits since ${base_ref})"

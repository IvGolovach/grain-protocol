{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grain.local/sdk/trust/trust_anchor_bundle_v1.schema.json",
  "title": "Grain Trust Anchor Bundle v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["bundle_v", "anchors"],
  "properties": {
    "bundle_v": {
      "const": 1
    },
    "anchors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "trust_pub_b64"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "^\\S(?:.*\\S)?$"
          },
          "trust_pub_b64": {
            "type": "string",
            "minLength": 1,
            "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
          }
        }
      }
    }
  }
}

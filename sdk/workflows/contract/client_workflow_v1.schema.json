{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://grain.local/sdk/workflows/contract/client_workflow_v1.schema.json",
  "title": "Grain SDK Client Workflow Fixture v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["fixture_id", "workflow", "strict", "input", "expect", "meta"],
  "properties": {
    "fixture_id": {
      "type": "string",
      "pattern": "^SDK-WF-[A-Z0-9-]+$"
    },
    "workflow": {
      "type": "string",
      "enum": [
        "scan_preview",
        "scan_accept",
        "scan_handoff",
        "device_lifecycle",
        "pairing",
        "sync_bundle",
        "store_snapshot"
      ]
    },
    "strict": {
      "const": true
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "qr_string_ref": {
          "$ref": "#/$defs/ref"
        },
        "trust_pub_b64_ref": {
          "$ref": "#/$defs/ref"
        },
        "trust_pub_b64": {
          "type": "string"
        },
        "trust_anchor_id": {
          "type": "string"
        },
        "trust_anchor_bundle_ref": {
          "$ref": "#/$defs/trust_bundle_ref"
        },
        "accept_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "import_attempts": {
          "type": "integer",
          "minimum": 1
        },
        "root_label": {
          "type": "string"
        },
        "device_label": {
          "type": "string"
        },
        "handoff_source": {
          "type": "string",
          "enum": [
            "manual_entry",
            "camera",
            "injected",
            "share_sheet",
            "deep_link",
            "clipboard",
            "robot_vision",
            "external_sensor",
            "unknown"
          ]
        }
      },
      "not": {
        "required": ["trust_pub_b64_ref", "trust_pub_b64"]
      },
      "dependentRequired": {
        "trust_anchor_bundle_ref": ["trust_anchor_id"]
      },
      "allOf": [
        {
          "not": {
            "required": ["trust_anchor_bundle_ref", "trust_pub_b64_ref"]
          }
        },
        {
          "not": {
            "required": ["trust_anchor_bundle_ref", "trust_pub_b64"]
          }
        }
      ]
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "oneOf": [
        {
          "required": ["diag"]
        },
        {
          "required": ["diag_contains"]
        }
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "Verified",
            "Untrusted",
            "Accepted",
            "AlreadyAccepted",
            "Created",
            "Valid",
            "Paired",
            "AlreadyPaired",
            "Ready",
            "Uninitialized",
            "Exported",
            "Restored",
            "Empty",
            "Imported",
            "AlreadyImported",
            "Rejected"
          ]
        },
        "diag": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "diag_contains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "cose_b64": {
          "$ref": "#/$defs/presence"
        },
        "store_mutation": {
          "type": "string",
          "enum": ["none", "accepted_scan_inserted"]
        },
        "accepted_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "device_count": {
          "type": "integer",
          "minimum": 0
        },
        "revoked_count": {
          "type": "integer",
          "minimum": 0
        },
        "lifecycle_event_count": {
          "type": "integer",
          "minimum": 0
        },
        "root_kid": {
          "$ref": "#/$defs/presence"
        },
        "active_ak": {
          "$ref": "#/$defs/presence"
        },
        "device_ak": {
          "$ref": "#/$defs/presence"
        },
        "pairing_id": {
          "$ref": "#/$defs/presence"
        },
        "envelope_b64": {
          "$ref": "#/$defs/presence"
        },
        "bundle_b64": {
          "$ref": "#/$defs/presence"
        },
        "snapshot_b64": {
          "$ref": "#/$defs/presence"
        },
        "handoff_source": {
          "type": "string",
          "enum": [
            "manual_entry",
            "camera",
            "injected",
            "share_sheet",
            "deep_link",
            "clipboard",
            "robot_vision",
            "external_sensor",
            "unknown"
          ]
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["desc"],
      "properties": {
        "desc": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "ref": {
      "type": "string",
      "pattern": "^conformance/vectors/[A-Za-z0-9_/-]+\\.json#/[A-Za-z0-9_~./-]+$"
    },
    "trust_bundle_ref": {
      "type": "string",
      "pattern": "^sdk/trust/fixtures/[A-Za-z0-9_-]+\\.json$"
    },
    "presence": {
      "type": "string",
      "enum": ["present", "absent"]
    }
  }
}

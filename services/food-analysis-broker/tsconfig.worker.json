{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["ES2022", "WebWorker"],
    "types": []
  },
  "include": [
    "src/analyzers.ts",
    "src/auth.ts",
    "src/dependencies.ts",
    "src/errors.ts",
    "src/handler.ts",
    "src/nutrition.ts",
    "src/resolver.ts",
    "src/runtime.ts",
    "src/schema.ts",
    "src/search.ts",
    "src/types.ts",
    "src/usage.ts",
    "src/usda.ts",
    "src/validation.ts",
    "src/worker.ts"
  ]
}
